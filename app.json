{
  "expo": {
    "name": "Civic Puzzle",
    "slug": "civic-puzzle",
    "version": "8.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpeg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laxatechnology.civicpuzzle",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use identifiers to deliver relevant ads and measure ad performance.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.laxatechnology.civicpuzzle",
      "versionCode": 8,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "permissions": []
    },
    "plugins": [
      "expo-notifications",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511"
        }
      ]
    ],
    "extra": {
      "privacyPolicyUrl": "https://civicpuzzle.onrender.com/privacy",
      "termsUrl": "https://civicpuzzle.onrender.com/terms",
      "disclaimerUrl": "https://civicpuzzle.onrender.com/disclaimer",
      "admob": {
        "androidBannerId": "ca-app-pub-3940256099942544/6300978111",
        "iosBannerId": "ca-app-pub-3940256099942544/2934735716"
      },
      "eas": {
        "projectId": "e9207585-6e7f-4663-8386-a6c94be078d9"
      }
    }
  }
}