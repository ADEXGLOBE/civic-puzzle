{
  "expo": {
    "name": "Civic Puzzle",
    "slug": "civic-puzzle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.jpg",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.laxatechnology.civicpuzzle",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use identifiers to deliver relevant ads and measure ad performance."
      }
    },
    "android": {
      "package": "com.laxatechnology.civicpuzzle",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#020617"
      },
      "permissions": []
    },
    "extra": {
      "privacyPolicyUrl": "https://YOUR_DOMAIN/privacy",
      "eas": {
        "projectId": "e9207585-6e7f-4663-8386-a6c94be078d9"
      }
    }
  }
}
